# ── Invest in Cuba — Opportunity Atlas ────────────────────────────────────────
# Copy to .env.local for local dev. No secrets are required to run the site:
# the map uses keyless Esri World Imagery satellite tiles by default.

# OPTIONAL — drop a billing-enabled Google Maps Platform key here to switch the
# map provider to Google satellite (the map adapter auto-detects it). Leave blank
# to use the keyless Esri satellite basemap.
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=

# OPTIONAL — AngelList SPV / fund URL the Layer-1 "Invest" CTA hands off to.
# If blank, the Invest CTA shows a "fund opening soon" interest state instead.
NEXT_PUBLIC_ANGELLIST_FUND_URL=

# ── Agentic worker (scripts/worker.ts / Netlify Scheduled Function) ───────────
# Needed only when you wire the worker to the live Claude API. The shipped
# worker runs in DRY-RUN (mock) mode without this and never auto-publishes.
ANTHROPIC_API_KEY=

# Admin review screen passphrase (mock auth gate for v1).
ADMIN_PASSPHRASE=change-me
